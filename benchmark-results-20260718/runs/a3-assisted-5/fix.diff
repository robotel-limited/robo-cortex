 from .errors import NotAGitRepoError, ValidationError
 
 
+def has_commits(repo_root: Path) -> None:
+    """Check if the repository has at least one commit.
+
+    Raises ValidationError if there are no commits yet. This guard prevents
+    git commands like `git ls-tree HEAD` from failing with raw CalledProcessError.
+    """
+    try:
+        result = subprocess.run(
+            ["git", "rev-parse", "HEAD"],
+            cwd=repo_root,
+            capture_output=True,
+            text=True,
+            check=True,
+        )
+    except subprocess.CalledProcessError:
+        raise ValidationError(
+            "repository has no commits yet. Run 'git commit' to create at least one commit first."
+        )
+
