#!/bin/sh
# Repo-maintenance safety net (internal tooling, not part of the shipped
# package): blocks pushing anything except the curated `public-release`
# branch -> `main` to this project's public GitHub remote. `master` carries
# the full internal history (audit docs, "Etapa/Stage" commits) and must
# never reach the public repo -- this used to depend purely on discipline
# ("don't run a bare `git push` on master"); this hook makes it a hard
# technical gate instead, regardless of how the push is invoked (bare
# `git push`, `git push origin`, `git push origin master`, an explicit URL,
# etc. -- checked against the remote's resolved URL, not its name, so
# renaming a remote doesn't bypass this).
#
# Install (from repo root): cp scripts/git-hooks/pre-push .git/hooks/pre-push
#                            chmod +x .git/hooks/pre-push
# (Not auto-installed: .git/hooks/ isn't tracked by git, so a fresh clone
# needs this run once.)
#
# Override for the rare legitimate case: ROBO_CORTEX_ALLOW_INTERNAL_PUSH=1

PUBLIC_REPO_PATTERN='github\.com[:/]robotel-limited/robo-cortex'
remote_url="$2"

if ! echo "$remote_url" | grep -qE "$PUBLIC_REPO_PATTERN"; then
    exit 0  # not pushing to the public repo -- nothing to guard here
fi

if [ -n "$ROBO_CORTEX_ALLOW_INTERNAL_PUSH" ]; then
    exit 0  # explicit, deliberate override
fi

blocked=0
while read -r local_ref _local_sha remote_ref _remote_sha; do
    case "$local_ref" in
        refs/tags/*)
            continue  # release tags (e.g. v0.4.0) are fine
            ;;
    esac
    if [ "$local_ref" = "refs/heads/public-release" ] && [ "$remote_ref" = "refs/heads/main" ]; then
        continue  # the one sanctioned path: curated snapshot -> main
    fi
    echo "BLOCKED: refusing to push '$local_ref' -> '$remote_ref' to the public GitHub repo." >&2
    echo "Only 'public-release' -> 'main' (and tags) may reach this remote." >&2
    echo "Regenerate public-release from a cleaned master instead, or override explicitly with:" >&2
    echo "  ROBO_CORTEX_ALLOW_INTERNAL_PUSH=1 git push ..." >&2
    blocked=1
done

exit $blocked
